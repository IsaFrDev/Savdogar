# ─── Savdoon Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets to version control.

# ─── Django Core ─────────────────────────────────────────────────────────────
# REQUIRED. Must be at least 50 characters and cryptographically random.
# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to True only for local development. NEVER True in production.
DJANGO_DEBUG=False

# Comma-separated list of hostnames the backend will serve.
# Must NOT include * in production. Example: savdoon.uz,www.savdoon.uz
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. SQLite is only acceptable for local development.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://savdoon_user:your-db-password-here@localhost:5432/savdoon_db

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# For Gmail, use an App Password (not your account password).
# See: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ─── AI / Gemini ──────────────────────────────────────────────────────────────
# Google Gemini API key. Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend-domain.com
BACKEND_URL=https://your-backend-domain.com

# ─── Redis (required for WebSocket real-time features in production) ──────────
# Format: redis://HOST:PORT/DB_NUMBER
# REDIS_URL=redis://localhost:6379/0

# ─── Optional: Field Encryption ───────────────────────────────────────────────
# Fernet key for encrypting sensitive model fields.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FIELD_ENCRYPTION_KEY=your-fernet-key-here

# ─── Optional: WebAuthn (Face ID) ─────────────────────────────────────────────
# WEBAUTHN_RP_ID=your-domain.com
# WEBAUTHN_ORIGIN=https://your-frontend-domain.com

# ─── Optional: Cookie Security ────────────────────────────────────────────────
# Set to True in production (requires HTTPS)
# SESSION_COOKIE_SECURE=True
